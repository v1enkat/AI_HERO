# --- Server (Node API) — repo root .env ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# --- Client (Vite) — optional overrides ---
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
# VITE_GROQ_API_KEY=          # browser-direct only; prefer GROQ_API_KEY on server
# VITE_API_URL=               # e.g. https://api.yourdomain.com when client is on another host
# VITE_GROQ_DIRECT=1        # call Groq from the browser (static hosting; needs key + CORS)
