{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch HER-AI",
            "url": "http://localhost:5500",
            "webRoot": "${workspaceFolder}",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-debug-userdata",
            "runtimeArgs": ["--remote-debugging-port=9222"],
            "preLaunchTask": "Start HTTP Server"
        }
    ]
}